function showTestIntro(){ renderTemplate('intro-template'); }
function showPersonas(){ renderTemplate('personas-template'); const grid=document.getElementById('personaGrid'); grid.innerHTML=Object.entries(PERSONAS).map(([code,p])=>`<article class="persona-card"><div class="icon">${p.icon}</div><div class="code">${code} · ${p.short}</div><h3>${p.name}</h3><p>${p.line}</p></article>`).join(''); }
function showHistory(){ renderTemplate('history-template'); renderHistory(); }

function startTest(){
  const ok = document.getElementById('consentCheck')?.checked;
  if(!ok){ alert('请先阅读并勾选同意说明。'); return; }
  state = { idx:0, answers:{}, startedAt:new Date().toISOString(), anonId: getAnonId() };
  renderQuestion();
}
function getAnonId(){
  let id = localStorage.getItem('emojiPersonaAnonId');
  if(!id){ id = 'EP-' + Math.random().toString(36).slice(2,10) + '-' + Date.now().toString(36); localStorage.setItem('emojiPersonaAnonId', id); }
  return id;
}

function renderQuestion(){
  const q = questions[state.idx];
  const pct = Math.round((state.idx)/questions.length*100);
  app.innerHTML = `
    <div class="progress-wrap">
      <div class="progress-meta"><span>${q.section}</span><span>${state.idx+1} / ${questions.length}</span></div>
      <div class="progress"><div class="progress-bar" style="width:${pct}%"></div></div>
    </div>
    <section class="question-card" id="qbox"></section>
  `;
  const box = document.getElementById('qbox');
  if(q.type === 'likert') box.innerHTML = renderLikert(q);
  else if(q.type === 'scenario') box.innerHTML = renderScenario(q);
  else if(q.type === 'attention') box.innerHTML = renderAttention(q);
  else box.innerHTML = renderSingle(q);
  updateSelected();
  window.scrollTo({top:0,behavior:'smooth'});
}
function navButtons(){
  return `<div class="test-actions"><button class="secondary" onclick="prevQuestion()" ${state.idx===0?'disabled':''}>上一题</button><button class="primary" onclick="nextQuestion()">${state.idx===questions.length-1?'提交并查看结果':'下一题'}</button></div>`;
}
function renderLikert(q){
  const labels = ['非常不同意','不同意','一般','同意','非常同意'];
  return `<div class="q-title">${q.text}</div><div class="q-help">请选择最符合你真实感受的一项。</div><div class="likert">${[1,2,3,4,5].map((n,i)=>optionHtml(q.id,n,`<span class="num">${n}</span><span class="lab">${labels[i]}</span>`)).join('')}</div>${navButtons()}`;
}
function renderAttention(q){
  const labels = ['非常不同意','不同意','一般','同意','非常同意'];
  return `<div class="q-title">${q.text}</div><div class="q-help">这是注意力检测题。</div><div class="likert">${[1,2,3,4,5].map((n,i)=>optionHtml(q.id,n,`<span class="num">${n}</span><span class="lab">${labels[i]}</span>`)).join('')}</div>${navButtons()}`;
}
function renderSingle(q){
  return `<div class="q-title">${q.text}</div><div class="answer-list">${q.options.map((op,i)=>optionHtml(q.id,i,op)).join('')}</div>${navButtons()}`;
}
function renderScenario(q){
  return `<div class="chat-scenario">
    <div class="sender-line"><div class="avatar">💬</div><div class="sender-meta"><strong>${q.sender}</strong><span>备注：${q.relation}</span></div></div>
    <div class="message">${q.message}</div>
  </div>
  <div class="q-title">${q.prompt}</div>
  <div class="answer-list">${q.options.map((op,i)=>optionHtml(q.id,i,op)).join('')}</div>${navButtons()}`;
}
function optionHtml(id,value,label){
  return `<label class="option" data-q="${id}" data-v="${value}" onclick="selectAnswer('${id}', '${value}')"><input type="radio" name="${id}" value="${value}" /> <span>${label}</span></label>`;
}
function selectAnswer(id,value){
  const q = questions.find(x=>x.id===id);
  state.answers[id] = (q.type==='likert'||q.type==='attention') ? Number(value) : Number(value);
  updateSelected();
}
function updateSelected(){
  document.querySelectorAll('.option').forEach(el=>{
    const q=el.dataset.q, v=Number(el.dataset.v);
    el.classList.toggle('selected', state.answers[q] === v);
    const inp=el.querySelector('input'); if(inp) inp.checked = state.answers[q] === v;
  });
}
function prevQuestion(){ if(state.idx>0){ state.idx--; renderQuestion(); } }
function nextQuestion(){
  const q = questions[state.idx];
  if(state.answers[q.id] === undefined){ alert('这一题还没有选择哦。'); return; }
  if(state.idx < questions.length-1){ state.idx++; renderQuestion(); }
  else submitTest();
}

function submitTest(){
  const result = calculateResult();
  const record = { anonId:state.anonId, startedAt:state.startedAt, submittedAt:new Date().toISOString(), answers:state.answers, ...result };
  saveRecord(record);
  sendToBackend(record);
  renderResult(record);
}

function avg(ids){ return ids.reduce((s,id)=>s+(Number(state.answers[id])||0),0)/ids.length; }
function calculateResult(){
  const dims = {
    CS: avg(['CS1','CS2','CS3','CS4','CS5']),
    SSA: avg(['SSA1','SSA2','SSA3','SSA4','SSA5']),
    IR: avg(['IR1','IR2','IR3','IR4','IR5']),
    SU: avg(['SU1','SU2','SU3','SU4','SU5']),
    MRA: avg(['MRA1','MRA2','MRA3','MRA4','MRA5'])
  };
  const extras = {CS:0,SSA:0,IR:0,SU:0,MRA:0,W:0,D:0};
  const emoji = {smile:0, ok:0, bye:0, laugh:0, cry:0, sweat:0, eye:0};
  for(const q of questions){
    const ans = state.answers[q.id];
    if(ans === undefined) continue;
    if(q.weights && q.weights[ans]){
      for(const [k,v] of Object.entries(q.weights[ans])) extras[k] = (extras[k]||0)+v;
    }
    if(q.emojiScores){
      for(const [key,arr] of Object.entries(q.emojiScores)) emoji[key] = (emoji[key]||0)+(arr[ans]||0);
    }
  }
  const combined = {
    CS: dims.CS + extras.CS*0.12,
    SSA: dims.SSA + extras.SSA*0.12,
    IR: dims.IR + extras.IR*0.12,
    SU: dims.SU + extras.SU*0.12,
    MRA: dims.MRA + extras.MRA*0.12
  };
  const letter1 = combined.CS >= 3.5 ? 'C' : 'O';
  const radarScore = (combined.SSA + combined.IR)/2;
  const letter2 = radarScore >= 3.5 ? 'R' : 'W';
  const implicitScore = (combined.IR + combined.SU)/2;
  const letter3 = implicitScore >= 3.5 ? 'I' : 'D';
  const letter4 = combined.MRA >= 3.5 ? 'S' : 'F';
  const code = `${letter1}${letter2}${letter3}${letter4}`;
  const persona = PERSONAS[code] || PERSONAS['CRIS'];
  const topEmojiKey = Object.entries(emoji).sort((a,b)=>b[1]-a[1])[0][0];
  const tag = TAGS[topEmojiKey] || TAGS.smile;
  const attentionPass = state.answers.ATTN1 === 4;
  return { dims, combined, code, personaName: persona.name, personaShort: persona.short, personaIcon: persona.icon, personaLine: persona.line, personaDesc: persona.desc, tagKey: topEmojiKey, tagName: tag.name, tagEmoji: tag.emoji, tagDesc: tag.desc, attentionPass };
}

function renderResult(r){
  app.innerHTML = `<section class="card">
    <div class="result-hero">
      <div class="result-icon">${r.personaIcon}</div>
      <div class="result-code">${r.code} · ${r.personaShort}</div>
      <div class="result-title">${r.personaName}</div>
      <span class="tag">${r.tagEmoji} ${r.tagName}</span>
      <p style="margin-top:16px;font-size:18px;"><strong>${r.personaLine}</strong></p>
      <p>${r.personaDesc}</p>
      <p class="muted">${r.tagDesc}</p>
    </div>
    <div class="score-grid">${scoreCard('语境敏感度',r.dims.CS)}${scoreCard('语义偏移感知',r.dims.SSA)}${scoreCard('隐含义识别',r.dims.IR)}${scoreCard('策略性使用',r.dims.SU)}${scoreCard('误解风险意识',r.dims.MRA)}</div>
    ${!r.attentionPass?'<p class="error">提示：你的注意力检测题未通过，该记录可能不会被纳入正式研究分析。</p>':''}
    <div class="hero-actions">
      <button class="primary" onclick="showTestIntro()">重新测试</button>
      <button class="secondary" onclick="showPersonas()">查看全部人格</button>
      <button class="secondary" onclick="showHistory()">查看本机记录</button>
    </div>
  </section>`;
  window.scrollTo({top:0,behavior:'smooth'});
}
function scoreCard(name,val){ const pct = Math.max(0,Math.min(100, val/5*100)); return `<div class="score-card"><b>${name}</b><span>${val.toFixed(2)} / 5</span><div class="score-bar"><span style="width:${pct}%"></span></div></div>`; }

function saveRecord(record){
  const arr = JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]');
  arr.unshift(record);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(arr.slice(0,20)));
}
function renderHistory(){
  const arr = JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]');
  const box = document.getElementById('historyBox');
  if(!arr.length){ box.innerHTML='<p class="muted">这台设备上还没有测试记录。</p>'; return; }
  box.innerHTML = arr.map((r,i)=>`<div class="history-item"><strong>${r.personaIcon} ${r.personaName} · ${r.tagEmoji} ${r.tagName}</strong><br/><span class="muted">${new Date(r.submittedAt).toLocaleString()} · ${r.code}</span><div style="margin-top:8px"><button class="secondary small" onclick="renderResultFromHistory(${i})">查看结果</button></div></div>`).join('');
}
function renderResultFromHistory(i){ const arr = JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]'); if(arr[i]) renderResult(arr[i]); }
function clearHistory(){ if(confirm('确定清除这台设备上的测试记录吗？后台已提交的数据不会被删除。')){ localStorage.removeItem(STORAGE_KEY); renderHistory(); } }

function flattenRecord(record){
  const flat = {
    anonId: record.anonId, startedAt:record.startedAt, submittedAt:record.submittedAt,
    gender: record.answers.gender, grade: record.answers.grade, wechat_time:record.answers.wechat_time, emoji_freq:record.answers.emoji_freq,
    CS: record.dims.CS, SSA:record.dims.SSA, IR:record.dims.IR, SU:record.dims.SU, MRA:record.dims.MRA,
    code:record.code, personaName:record.personaName, tagKey:record.tagKey, tagName:record.tagName, attentionPass:record.attentionPass,
    rawAnswers: JSON.stringify(record.answers)
  };
  for(const q of questions){ flat[q.id] = record.answers[q.id] ?? ''; }
  return flat;
}
function sendToBackend(record){
  if(!BACKEND_URL) return;
  const payload = flattenRecord(record);
  try{
    // no-cors 适配 Google Apps Script 简单跨域提交；不能读取返回值，但能写入表格。
    fetch(BACKEND_URL, {method:'POST', mode:'no-cors', headers:{'Content-Type':'text/plain;charset=utf-8'}, body:JSON.stringify(payload)});
  }catch(e){ console.warn('Backend submission failed', e); }
}

showHome();

/**
 * Google Apps Script 后台：接收测试结果写入 Google Sheet。
 * 使用步骤：
 * 1. 新建一个 Google Sheet。
 * 2. 扩展程序 → Apps Script。
 * 3. 粘贴本文件代码，保存。
 * 4. 部署 → 新建部署 → 类型选择“网页应用”。
 * 5. 执行身份选择“我”，访问权限选择“任何人”。
 * 6. 复制 Web App URL，填入前端 app.js 的 BACKEND_URL。
 */

const SHEET_NAME = 'responses';

function doPost(e) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.insertSheet(SHEET_NAME);
    const data = JSON.parse(e.postData.contents || '{}');

    const headers = getHeaders_(data);
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(headers);
    } else {
      const currentHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
      const missing = headers.filter(h => !currentHeaders.includes(h));
      if (missing.length) {
        sheet.getRange(1, currentHeaders.length + 1, 1, missing.length).setValues([missing]);
      }
    }

    const finalHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    const row = finalHeaders.map(h => data[h] !== undefined ? data[h] : '');
    sheet.appendRow(row);

    return ContentService.createTextOutput(JSON.stringify({ ok: true }))
      .setMimeType(ContentService.MimeType.JSON);
  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({ ok: false, error: String(err) }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}

function getHeaders_(data) {
  const preferred = [
    'anonId','startedAt','submittedAt','gender','grade','wechat_time','emoji_freq',
    'CS','SSA','IR','SU','MRA','code','personaName','tagKey','tagName','attentionPass'
  ];
  const questionIds = [
    'CS1','CS2','CS3','CS4','CS5','SSA1','SSA2','SSA3','SSA4','SSA5',
    'IR1','IR2','IR3','IR4','IR5','SU1','SU2','SU3','SU4','SU5',
    'MRA1','MRA2','MRA3','MRA4','MRA5','ATTN1',
    'S1','S2','S3','S4','S5','S6','S7','S8','S9','S10','S11','S12',
    'F1','F2','F3','F4','F5'
  ];
  const rest = Object.keys(data).filter(k => !preferred.includes(k) && !questionIds.includes(k) && k !== 'rawAnswers');
  return preferred.concat(questionIds).concat(rest).concat(['rawAnswers']);
}

